{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.4",
  "default_locale": "en",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "ikon128.png"
    }
  },
  "icons": {
    "128": "ikon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://steamcommunity.com/market/listings/730/*"],
      "js": ["isolated.js"],
      "run_at": "document_end",
      "world": "ISOLATED"
    },
    {
      "matches": ["*://steamcommunity.com/market/listings/730/*"],
      "js": ["main.js"],
      "run_at": "document_end",
      "world": "MAIN"
    }
  ]
}